{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanish-hire",
  "compatibility_date": "2026-07-03",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public"
  },
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    { "pattern": "tanishhire.com", "custom_domain": true }
  ]
}
